# ─── Frontend (Vite) — públicas, prefixo VITE_ ─────────────────────
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ─── Backend (Vercel Functions) — NUNCA expor no client ────────────
# Service role do Supabase pra bypass de RLS quando necessário (ex: APIs
# que precisam ler/escrever em qualquer linha — Spotify tokens, push subs).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Cloudflare Stream (vídeos do feed/stories) ────────────────────
CLOUDFLARE_ACCOUNT_ID=<...>
CLOUDFLARE_STREAM_TOKEN=<...>

# ─── Web Push (Service Worker) ─────────────────────────────────────
VAPID_PUBLIC_KEY=<...>
VAPID_PRIVATE_KEY=<...>

# ─── APNs (iOS push via Capacitor) ─────────────────────────────────
APNS_KEY_ID=<...>
APNS_TEAM_ID=<...>
APNS_AUTH_KEY=<.p8 em base64 ou com \n literais>

# ─── Anthropic (Claude — moderação automática) ─────────────────────
ANTHROPIC_API_KEY=<...>

# ─── Groq (tradução de áudio) ──────────────────────────────────────
GROQ_API_KEY=<...>

# ─── Spotify — Integração nova ─────────────────────────────────────
# Pra configurar:
# 1. Vá em https://developer.spotify.com/dashboard
# 2. Crie um app (ou use existente)
# 3. Em "Edit Settings" → "Redirect URIs" adicione TODOS abaixo:
#    - http://127.0.0.1:3000/api/auth/spotify/callback   (IMPORTANTE: 127.0.0.1, NÃO localhost)
#    - https://studentclub-br.vercel.app/api/auth/spotify/callback
#    - https://papodealunos.com/api/auth/spotify/callback
# 4. Copie o Client ID e Client Secret aqui.
# 5. Use o redirect que bater com o ambiente (dev / preview / prod).
SPOTIFY_CLIENT_ID=<seu-client-id-publico-do-spotify-dashboard>
SPOTIFY_CLIENT_SECRET=<seu-client-secret-do-spotify-dashboard>
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# Chave de criptografia dos tokens Spotify armazenados no DB (AES-256-GCM).
# Gere com: openssl rand -hex 32
# Resultado: string hexadecimal de 64 caracteres.
SPOTIFY_TOKEN_ENCRYPTION_KEY=<64-char-hex-string>
